VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Edge function environment variables (set in Supabase project settings or .env for local dev)
# These can also be configured via the Settings tab in the app.
# EXA_API_KEY=           # Exa API key for Websets + Search
# PARALLEL_API_KEY=      # Parallel AI API key for task groups
# ANTHROPIC_API_KEY=     # Claude API key
# GITHUB_TOKEN=          # GitHub PAT for repo/user lookups (read:user scope)
